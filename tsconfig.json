{
  "compilerOptions": {
    "target": "ES2022", "module": "NodeNext", "moduleResolution": "NodeNext",
    "outDir": "dist", "rootDir": "server/src", "strict": true, "esModuleInterop": true,
    "skipLibCheck": true, "resolveJsonModule": true, "declaration": false, "sourceMap": true
  },
  "include": ["server/src/**/*.ts"]
}
