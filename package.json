{
  "name": "pad-tracker-server",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch server/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/src/db/migrate.ts"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1",
    "zod": "^3.23.8",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5",
    "drizzle-kit": "^0.28.1",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7"
  }
}
