# 구성 A(단일 EC2)용 환경. 복사해서 값 채우기:  cp .env.prod.example .env
# ⚠️ .env / secrets/ 는 커밋 금지 (레포 .gitignore 처리).

# 공인 도메인 (이 호스트로 A레코드 연결)
DOMAIN=pad.example.com

# PostgreSQL (compose 내부 db 서비스)
POSTGRES_USER=pad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=padtracker
DATABASE_URL=postgres://pad:change-me-strong-db-password@db:5432/padtracker

# API
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
TRUST_PROXY=true
CORP_PUBLIC_IPS=203.0.113.0/24,198.51.100.5
CORP_SSIDS=CORP-WIFI,CORP-WIFI-5G
RETENTION_DAYS=90
STALE_DAYS=7
RUN_MIGRATIONS=true

# FCM 서비스계정: 파일 경로(권장, ../secrets/에 두고 마운트) 또는 JSON 내용 자체
FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# (선택) MaxMind GeoLite2 mmdb 경로
MAXMIND_MMDB_PATH=
