# NCP 구성(로컬 원본)용 환경. 복사:  cp .env.example .env    (⚠️ .env 커밋 금지)
#
# 전제: wjtools.wjthinkbig.com 은 NCP CDN+(원본=버킷)로 "정적만" 서빙 → 동적 API는 같은 경로로
# 통과 불가. 그래서 API는 "별도 호스트 + CORS" 로 노출한다(권장 구성 A).
#   - 프론트: 버킷 ai-srt-corrector/FindMyPad/  →  https://wjtools.wjthinkbig.com/FindMyPad
#   - API   : 이 로컬 박스              →  https://findmypad-api.wjthinkbig.com   (아래 API_DOMAIN)

# 이 로컬 박스(API)의 공개 도메인 — Caddy Let's Encrypt TLS. A레코드 → 이 박스 공인 IP.
API_DOMAIN=findmypad-api.wjthinkbig.com

# API는 자체 호스트 루트에서 서빙 → 접두사 없음(비움). (동일 호스트 하위경로일 때만 /FindMyPad)
BASE_PATH=

# 프론트가 다른 오리진(wjtools)이므로 CORS로 그 오리진 허용.
CORS_ORIGINS=https://wjtools.wjthinkbig.com

# PostgreSQL (로컬 컨테이너)
POSTGRES_USER=pad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=padtracker
DATABASE_URL=postgres://pad:change-me-strong-db-password@db:5432/padtracker

# API
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
CORP_PUBLIC_IPS=203.0.113.0/24,198.51.100.5
CORP_SSIDS=CORP-WIFI,CORP-WIFI-5G
RETENTION_DAYS=90
STALE_DAYS=7
RUN_MIGRATIONS=true

# FCM 서비스계정 (../secrets/ 에 두고 마운트) 또는 JSON 내용
FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# (선택) MaxMind mmdb
MAXMIND_MMDB_PATH=
