# NCP 구성(경로별 원본) 로컬 환경. 복사: cp .env.example .env  (⚠️ .env 커밋 금지)
#
# wjtools.wjthinkbig.com 하나만 사용 + 프록시/서브도메인 불가.
# NCP CDN+ 경로별 원본으로:  /FindMyPad/api/* → 이 박스 공인 IP:ORIGIN_PORT,  /FindMyPad/* → 버킷.

# CDN이 당길 공인 원본 포트 (CDN origin = http://<이 박스 공인 IP>:ORIGIN_PORT)
ORIGIN_PORT=8080

# 단일 호스트 하위경로 → API는 /FindMyPad/api 로 서빙.
BASE_PATH=/FindMyPad

# 같은 호스트(wjtools) → 동일 오리진 → CORS 비움.
CORS_ORIGINS=

# PostgreSQL (로컬 컨테이너)
POSTGRES_USER=pad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=padtracker
DATABASE_URL=postgres://pad:change-me-strong-db-password@db:5432/padtracker

# API
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
CORP_PUBLIC_IPS=203.0.113.0/24,198.51.100.5
CORP_SSIDS=CORP-WIFI,CORP-WIFI-5G
RETENTION_DAYS=90
STALE_DAYS=7
RUN_MIGRATIONS=true

# FCM 서비스계정 (../secrets/ 에 두고 마운트) 또는 JSON 내용
FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# (선택) MaxMind mmdb
MAXMIND_MMDB_PATH=
