# NCP 구성 B(단일 호스트 /FindMyPad) 로컬 원본 환경. 복사: cp .env.example .env  (⚠️ .env 커밋 금지)
#
# 구성 B: wjtools.wjthinkbig.com/FindMyPad 하나로 프론트+API. 프론트 계층에 리버스프록시를 둬서
#   /FindMyPad/api/*  → 이 로컬 API 원본(아래 API_DOMAIN)
#   /FindMyPad/*      → 버킷 ai-srt-corrector/FindMyPad/ (정적)
# 로 분기한다. (wjtools-proxy.nginx.conf 참고)

# 이 로컬 박스(API 원본)의 공개 도메인 — Caddy Let's Encrypt TLS. wjtools 프록시가 여기로 전달.
API_DOMAIN=findmypad-origin.wjthinkbig.com

# 단일 호스트 하위경로 → API는 /FindMyPad/api 로 서빙.
BASE_PATH=/FindMyPad

# 프론트와 API가 같은 호스트(wjtools) → 동일 오리진 → CORS 비움.
CORS_ORIGINS=

# PostgreSQL (로컬 컨테이너)
POSTGRES_USER=pad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=padtracker
DATABASE_URL=postgres://pad:change-me-strong-db-password@db:5432/padtracker

# API
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
CORP_PUBLIC_IPS=203.0.113.0/24,198.51.100.5
CORP_SSIDS=CORP-WIFI,CORP-WIFI-5G
RETENTION_DAYS=90
STALE_DAYS=7
RUN_MIGRATIONS=true

# FCM 서비스계정 (../secrets/ 에 두고 마운트) 또는 JSON 내용
FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# (선택) MaxMind mmdb
MAXMIND_MMDB_PATH=
