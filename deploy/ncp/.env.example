# NCP 구성(로컬 원본)용 환경. 복사:  cp .env.example .env    (⚠️ .env 커밋 금지)

# 이 로컬 박스(API 원본)의 자체 공개 도메인 — Caddy TLS 발급용.
# wjtools 프록시/CDN이 이 호스트로 /FindMyPad/api 를 전달한다.
API_DOMAIN=findmypad-origin.example.com

# 하위경로 배포: 서비스가 https://wjtools.wjthinkbig.com/FindMyPad 이므로 API는 /FindMyPad/api.
BASE_PATH=/FindMyPad

# CORS: 프론트와 API가 같은 호스트(wjtools.wjthinkbig.com)면 동일 오리진 → 비움.
# 만약 프론트가 다른 오리진이면 그 오리진을 넣는다(예: https://app.example.com).
CORS_ORIGINS=

# PostgreSQL (로컬 컨테이너)
POSTGRES_USER=pad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=padtracker
DATABASE_URL=postgres://pad:change-me-strong-db-password@db:5432/padtracker

# API
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
CORP_PUBLIC_IPS=203.0.113.0/24,198.51.100.5
CORP_SSIDS=CORP-WIFI,CORP-WIFI-5G
RETENTION_DAYS=90
STALE_DAYS=7
RUN_MIGRATIONS=true

# FCM 서비스계정 (../secrets/ 에 두고 마운트) 또는 JSON 내용
FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# (선택) MaxMind mmdb
MAXMIND_MMDB_PATH=
